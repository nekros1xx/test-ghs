#!/usr/bin/env bash
# ghascan — one-command wrapper around the dockerized producer/worker/collector
# pipeline. Gives the classic single-command UX (ghascan --org X --pdf out.pdf)
# while everything runs in Docker. Tokens live in the repo's .env; nothing to edit.
set -uo pipefail

# Locate the repo: honor $GHASCAN_HOME, else derive it from this script's path
# (works both when run as ./scripts/ghascan and via the installed shim).
SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"
GHASCAN_HOME="${GHASCAN_HOME:-$(cd "$(dirname "$SELF")/.." && pwd)}"
cd "$GHASCAN_HOME" || { echo "ghascan: cannot find the repo (set GHASCAN_HOME=/path/to/repo)"; exit 1; }

UI_PORT="${GHASCAN_UI_PORT:-9191}"

if [ ! -f .env ]; then
  echo "⚠  Missing $GHASCAN_HOME/.env — copy .env.example to .env and set your GITHUB_TOKEN." >&2
elif ! grep -qE '^GITHUB_TOKEN=[^[:space:]]+' .env; then
  echo "⚠  GITHUB_TOKEN is empty in .env — the scan will run ANONYMOUSLY (GitHub's 60 req/hr" >&2
  echo "   limit) and results will be incomplete. Edit .env and re-run." >&2
fi

dc() { docker compose "$@"; }

# True when nothing is listening on the given loopback TCP port.
port_free() { ! (exec 3<>"/dev/tcp/127.0.0.1/$1") 2>/dev/null; }

# No args → passthrough help from the image.
if [ $# -eq 0 ]; then dc run --rm -e GHASCAN_NO_BANNER=1 producer --help; exit $?; fi

# Ensure the infra is up. redis + workers are REQUIRED for the scan; the UI is
# best-effort (a busy port must not abort the run).
if ! dc ps --status running --services 2>/dev/null | grep -q '^worker$'; then
  echo "▶ Starting the stack (redis + workers)…"
  dc up -d redis worker >/dev/null || { echo "✗ Failed to start redis/workers."; exit 1; }
fi

# If THIS project's UI is already running, reuse it — don't bump to a new port or
# recreate the container (a busy 9191 is usually just our own dashboard from a prior run).
UI_URL=""
_ui_cid="$(dc ps -q ui 2>/dev/null)"
if [ -n "$_ui_cid" ] && [ "$(docker inspect -f '{{.State.Running}}' "$_ui_cid" 2>/dev/null)" = "true" ]; then
  # Recover the port from the running container's command (…--port N…).
  cur=""; mapfile -t _a < <(docker inspect -f '{{range .Args}}{{println .}}{{end}}' "$_ui_cid" 2>/dev/null)
  for ((i = 0; i < ${#_a[@]} - 1; i++)); do [ "${_a[i]}" = "--port" ] && cur="${_a[i+1]}"; done
  [ -z "$cur" ] && cur="$UI_PORT"
  UI_URL="http://127.0.0.1:$cur"
  echo "▶ Reusing the running dashboard: $UI_URL"
else
  # UI not up: walk from the preferred port to the next free one and start it there.
  start="$UI_PORT"
  while ! port_free "$UI_PORT"; do
    echo "ℹ  Port $UI_PORT is already in use, trying $((UI_PORT + 1))…" >&2
    UI_PORT=$((UI_PORT + 1))
    if [ "$UI_PORT" -gt $((start + 1000)) ]; then
      echo "✗ No free port in range $start-$UI_PORT; skipping the UI (scan continues)." >&2
      UI_PORT=""; break
    fi
  done
  if [ -n "$UI_PORT" ]; then
    export GHASCAN_UI_PORT="$UI_PORT"
    if dc up -d ui >/dev/null 2>&1; then
      UI_URL="http://127.0.0.1:$UI_PORT"
      echo "▶ Live dashboard: $UI_URL"
    else
      echo "⚠  UI did not start (scan continues)." >&2
    fi
  fi
fi

# Partition the classic-style args:
#   ORGS[]  — one or more orgs; --org accepts a comma list (--org a,b,c)
#   ENQ[]   — enqueue flags (discovery + limits, plus --repo/--user targets)
#   REP[]   — report-only filters/flags (-v, --verdict, --scanned, --repo/--user)
#   OUT_*   — a single output flag (--pdf/--html/-o), kept apart so it can be
#             suffixed per-org when several orgs are scanned.
ENQ=(); REP=(); ORGS=(); OUT_FLAG=""; OUT_NAME=""; OUT_FILES=(); HAVE_TARGET=0
while [ $# -gt 0 ]; do
  case "$1" in
    --pdf|--html) OUT_FLAG="$1"; OUT_NAME="$(basename "$2")"; shift 2;;
    -o|--output)  OUT_FLAG="-o"; OUT_NAME="$(basename "$2")"; shift 2;;
    --verdict)
      REP+=(--verdict); shift
      while [ $# -gt 0 ] && [ "${1#-}" = "$1" ]; do REP+=("$1"); shift; done;;
    -v|--verbose) REP+=(-v); shift;;
    --scanned)    REP+=(--scanned); shift;;
    --org)
      IFS=',' read -ra _orgs <<< "$2"
      for _o in "${_orgs[@]}"; do _o="${_o// /}"; [ -n "$_o" ] && ORGS+=("$_o"); done
      HAVE_TARGET=1; shift 2;;
    --repo) ENQ+=(--repo "$2"); REP+=(--repo "$2"); HAVE_TARGET=1; shift 2;;
    --user) ENQ+=(--user "$2"); REP+=(--org "$2"); HAVE_TARGET=1; shift 2;;
    --query|-q|--custom|-c|--all)
      ENQ+=("$1"); [ "$1" != "--all" ] && { ENQ+=("$2"); shift; }; HAVE_TARGET=1; shift;;
    --max-repos|--queue-high-water|--min-stars|--start-page|-s|--end-page|-e|--limit|-l)
      ENQ+=("$1" "$2"); shift 2;;
    --yolo|--no-subdivide) ENQ+=("$1"); shift;;
    *) ENQ+=("$1"); shift;;
  esac
done

# Build the report output arg for a filename suffix (empty = no suffix), and record
# the resolved host path in OUT_FILES for the final summary.
report_out_args=()
build_out() {  # $1 = suffix
  report_out_args=()
  [ -z "$OUT_FLAG" ] && return
  local name="$OUT_NAME"
  if [ -n "$1" ]; then
    if [[ "$OUT_NAME" == *.* ]]; then name="${OUT_NAME%.*}-$1.${OUT_NAME##*.}"; else name="${OUT_NAME}-$1"; fi
  fi
  report_out_args=("$OUT_FLAG" "/data/$name")
  OUT_FILES+=("$GHASCAN_HOME/data/$name")
}

# 1. Scan: enqueue each target, then wait once for the workers to drain the queue.
if [ "$HAVE_TARGET" -eq 1 ]; then
  if [ "${#ORGS[@]}" -gt 0 ]; then
    for org in "${ORGS[@]}"; do
      echo "▶ Enqueuing org: $org"
      dc run --rm -e GHASCAN_NO_BANNER=1 producer enqueue --org "$org" "${ENQ[@]}" || exit 1
    done
  else
    echo "▶ Enqueuing: ${ENQ[*]}"
    dc run --rm -e GHASCAN_NO_BANNER=1 producer enqueue "${ENQ[@]}" || exit 1
  fi
  echo -n "▶ Scanning"
  while :; do
    n="$(dc exec -T redis redis-cli llen rq:queue:default 2>/dev/null | tr -d '\r ')"
    [ -z "$n" ] && n=0
    [ "$n" = "0" ] && break
    echo -n " .${n}"; sleep 2
  done
  echo " ✓"
fi

# 2. Report from the shared DB: one report per org (with per-org output files when
# several orgs are scanned), otherwise a single report honoring any --repo/--user filter.
echo "▶ Generating report…"
if [ "${#ORGS[@]}" -gt 1 ]; then
  for org in "${ORGS[@]}"; do
    echo "──── $org ────"
    build_out "$org"
    dc run --rm -e GHASCAN_NO_BANNER=1 producer report --org "$org" "${REP[@]}" "${report_out_args[@]}" || exit 1
  done
elif [ "${#ORGS[@]}" -eq 1 ]; then
  build_out ""
  dc run --rm -e GHASCAN_NO_BANNER=1 producer report --org "${ORGS[0]}" "${REP[@]}" "${report_out_args[@]}" || exit 1
else
  build_out ""
  dc run --rm -e GHASCAN_NO_BANNER=1 producer report "${REP[@]}" "${report_out_args[@]}" || exit 1
fi

# Final summary — printed last so it survives the scrollback from enqueue/report.
echo
echo "────────────────────────────────────────────────────────"
for f in "${OUT_FILES[@]}"; do echo "  ✔ Report saved to: $f"; done
if [ -n "$UI_URL" ]; then
  echo "  📊 Live dashboard: $UI_URL"
  echo "     (open it in a browser to explore findings; stop everything with 'docker compose down')"
else
  echo "  ⚠  UI is not running — start it with 'docker compose up -d ui'"
fi
echo "────────────────────────────────────────────────────────"
