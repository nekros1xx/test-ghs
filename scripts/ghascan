#!/usr/bin/env bash
# ghascan — one-command wrapper around the dockerized producer/worker/collector
# pipeline. Gives the classic single-command UX (ghascan --org X --pdf out.pdf)
# while everything runs in Docker. Tokens live in the repo's .env; nothing to edit.
set -uo pipefail

# Locate the repo: honor $GHASCAN_HOME, else derive it from this script's path
# (works both when run as ./scripts/ghascan and via the installed shim).
SELF="$(readlink -f "$0" 2>/dev/null || echo "$0")"
GHASCAN_HOME="${GHASCAN_HOME:-$(cd "$(dirname "$SELF")/.." && pwd)}"
cd "$GHASCAN_HOME" || { echo "ghascan: cannot find the repo (set GHASCAN_HOME=/path/to/repo)"; exit 1; }

UI_PORT="${GHASCAN_UI_PORT:-9191}"

if [ ! -f .env ]; then
  echo "⚠  Missing $GHASCAN_HOME/.env — copy .env.example to .env and set your GITHUB_TOKEN." >&2
elif ! grep -qE '^GITHUB_TOKEN=[^[:space:]]+' .env; then
  echo "⚠  GITHUB_TOKEN is empty in .env — the scan will run ANONYMOUSLY (GitHub's 60 req/hr" >&2
  echo "   limit) and results will be incomplete. Edit .env and re-run." >&2
fi

dc() { docker compose "$@"; }

# True when nothing is listening on the given loopback TCP port.
port_free() { ! (exec 3<>"/dev/tcp/127.0.0.1/$1") 2>/dev/null; }

# No args → passthrough help from the image.
if [ $# -eq 0 ]; then dc run --rm producer --help; exit $?; fi

# Ensure the infra is up. redis + workers are REQUIRED for the scan; the UI is
# best-effort (a busy port must not abort the run).
if ! dc ps --status running --services 2>/dev/null | grep -q '^worker$'; then
  echo "▶ Starting the stack (redis + workers)…"
  dc up -d redis worker >/dev/null || { echo "✗ Failed to start redis/workers."; exit 1; }
fi

# Start the UI on a free host port: if the preferred one is taken, walk up to
# the next open port (9191 → 9192 → 9193 → …) and publish the UI there.
start="$UI_PORT"
while ! port_free "$UI_PORT"; do
  echo "ℹ  Port $UI_PORT is already in use, trying $((UI_PORT + 1))…" >&2
  UI_PORT=$((UI_PORT + 1))
  if [ "$UI_PORT" -gt $((start + 1000)) ]; then
    echo "✗ No free port in range $start-$UI_PORT; skipping the UI (scan continues)." >&2
    UI_PORT=""; break
  fi
done
UI_URL=""
if [ -n "$UI_PORT" ]; then
  export GHASCAN_UI_PORT="$UI_PORT"
  if dc up -d ui >/dev/null 2>&1; then
    UI_URL="http://127.0.0.1:$UI_PORT"
    echo "▶ Live dashboard: $UI_URL"
  else
    echo "⚠  UI did not start (scan continues)." >&2
  fi
fi

# Partition the classic-style args into enqueue (target/discovery) vs report (output/filter).
ENQ=(); REP=(); OUTHOST=""; HAVE_TARGET=0
while [ $# -gt 0 ]; do
  case "$1" in
    --pdf|--html|-o|--output)
      base="$(basename "$2")"
      case "$1" in -o|--output) REP+=(-o "/data/$base");; *) REP+=("$1" "/data/$base");; esac
      OUTHOST="$GHASCAN_HOME/data/$base"; shift 2;;
    --verdict)
      REP+=(--verdict); shift
      while [ $# -gt 0 ] && [ "${1#-}" = "$1" ]; do REP+=("$1"); shift; done;;
    -v|--verbose) REP+=(-v); shift;;
    --scanned)    REP+=(--scanned); shift;;
    --org)  ENQ+=(--org "$2");  REP+=(--org "$2"); HAVE_TARGET=1; shift 2;;
    --repo) ENQ+=(--repo "$2"); REP+=(--repo "$2"); HAVE_TARGET=1; shift 2;;
    --user) ENQ+=(--user "$2"); REP+=(--org "$2"); HAVE_TARGET=1; shift 2;;
    --query|-q|--custom|-c|--all)
      ENQ+=("$1"); [ "$1" != "--all" ] && { ENQ+=("$2"); shift; }; HAVE_TARGET=1; shift;;
    --max-repos|--queue-high-water|--min-stars|--org-max-repos|--start-page|-s|--end-page|-e|--limit|-l)
      ENQ+=("$1" "$2"); shift 2;;
    --yolo|--no-subdivide) ENQ+=("$1"); shift;;
    *) ENQ+=("$1"); shift;;
  esac
done

# 1. Scan: enqueue the target, then wait for the workers to drain the queue.
if [ "$HAVE_TARGET" -eq 1 ]; then
  echo "▶ Enqueuing: ${ENQ[*]}"
  dc run --rm producer enqueue "${ENQ[@]}" || exit 1
  echo -n "▶ Scanning"
  while :; do
    n="$(dc exec -T redis redis-cli llen rq:queue:default 2>/dev/null | tr -d '\r ')"
    [ -z "$n" ] && n=0
    [ "$n" = "0" ] && break
    echo -n " .${n}"; sleep 2
  done
  echo " ✓"
fi

# 2. Report from the shared DB.
echo "▶ Generating report…"
dc run --rm producer report "${REP[@]}" || exit 1

# Final summary — printed last so it survives the scrollback from enqueue/report.
echo
echo "────────────────────────────────────────────────────────"
[ -n "$OUTHOST" ] && echo "  ✔ Report saved to: $OUTHOST"
if [ -n "$UI_URL" ]; then
  echo "  📊 Live dashboard: $UI_URL"
  echo "     (open it in a browser to explore findings; stop everything with 'docker compose down')"
else
  echo "  ⚠  UI is not running — start it with 'docker compose up -d ui'"
fi
echo "────────────────────────────────────────────────────────"
