# ghascan environment — copy this file to `.env` and fill in your own values.
#   cp .env.example .env
# `.env` is gitignored and must NEVER be committed (it holds secrets).

# --- Workers / producer: GitHub API auth ---------------------------------
# One or more GitHub Personal Access Tokens, comma-separated for round-robin
# (higher combined rate limit). A classic PAT with public_repo/repo scope works.
#   GITHUB_TOKEN=ghp_aaa,ghp_bbb,ghp_ccc
GITHUB_TOKEN=

# --- UI: Claude Code chat panel auth (optional) --------------------------
# Only needed if you use the UI's chat panel. Leave empty to skip.
CLAUDE_CODE_OAUTH_TOKEN=
